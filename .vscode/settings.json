{
  "editor.formatOnSave": true,
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 200,
  "dart.lineLength": 200,
  "git.postCommitCommand": "push",
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.organizeImports": "always"
  },
  "chat.editing.autoAcceptDelay": 60,
  // "dart.flutterSdkPath": ".fvm/versions/3.27.4"
  "editor.tabSize": 2, // 设置 Tab 键为 2 个空格
  "editor.insertSpaces": true, // 使用空格而不是制表符
  "editor.detectIndentation": false, // 禁用自动检测缩进，强制使用设定的缩进
  "[swift]": {
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.hover.enabled": "off",
    "editor.semanticHighlighting.enabled": false
  },
  "swift.diagnostics.enable": false
}